# Copy this file to .env.local and fill in the keys.
# .env.local is gitignored. Never commit real keys.

# --- Multi-LLM analysis (all four are used) ---
# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Perplexity (Sonar synthesis) — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Market data (quotes/history) uses Yahoo Finance — no API key required.

# --- 13F holdings (SEC EDGAR) ---
# SEC requires a descriptive User-Agent (no key). Defaults to a placeholder.
SEC_USER_AGENT=
# OpenFIGI CUSIP->ticker mapping. Optional: works without a key (25 req/min),
# a free key raises the limit and resolves large portfolios faster.
OPENFIGI_API_KEY=

# --- Korean fundamentals for the comparables feature (optional) ---
# OpenDART (전자공시) — https://opendart.fss.or.kr/  (free key)
# Fills PER/EPS/PBR/ROE/margins for KRX-listed peers. Without it, those
# fields show "데이터 없음" (no fake numbers).
DART_API_KEY=
