# Copy this file to .env.local and fill in only the keys you need.
# .env.local is gitignored. Never commit real keys.

# --- Multi-LLM analysis ---
# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Perplexity (Sonar synthesis) — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# --- Market data providers (K-Fin terminal) ---
FINNHUB_API_KEY=
POLYGON_API_KEY=
FRED_API_KEY=
OPENDART_API_KEY=
# Contact email for SEC EDGAR requests (required by SEC fair-access policy)
SEC_USER_AGENT=

# --- Local user storage secrets (K-Fin terminal). Dev defaults used if omitted. ---
KFIN_SESSION_SECRET=
KFIN_ENCRYPTION_KEY=
KFIN_LOCAL_SECRET=
# Set to "true" to allow live order placement
KFIN_ENABLE_LIVE_ORDERS=false

# --- Daily analysis cron → Telegram alerts (scripts/daily-analysis.mjs) ---
NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3200
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
