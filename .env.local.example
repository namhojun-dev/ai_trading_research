# Copy this file to .env.local and fill in only the keys you need.
# .env.local is gitignored. Never commit real keys.

# K-Fin Terminal market data extensions
FINNHUB_API_KEY=
POLYGON_API_KEY=
FRED_API_KEY=
OPENDART_API_KEY=

# Local user storage secrets. If omitted, local development defaults are used.
KFIN_SESSION_SECRET=
KFIN_ENCRYPTION_KEY=

# OpenAI (GPT)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_LIFEOS_MODEL=gpt-5-mini
LIFEOS_ENABLE_OPENAI_COACHING=false

# LifeOS AI
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
LIFEOS_DEMO_USER_ID=
LIFEOS_ENCRYPTION_KEY=
LIFEOS_JWT_SECRET=
LIFEOS_CRON_SECRET=
LIFEOS_APP_BASE_URL=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_SERVER_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Gemini
# https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Perplexity (Sonar)
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
