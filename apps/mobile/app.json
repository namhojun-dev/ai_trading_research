{
  "expo": {
    "name": "LifeOS AI",
    "slug": "lifeos-ai",
    "scheme": "lifeos",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "ai.lifeos.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "ai.lifeos.mobile",
      "permissions": ["POST_NOTIFICATIONS", "PACKAGE_USAGE_STATS", "ACTIVITY_RECOGNITION"]
    },
    "extra": {
      "apiBaseUrl": "http://127.0.0.1:3200"
    }
  }
}
